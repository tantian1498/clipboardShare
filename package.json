{
  "name": "clipboard-share",
  "version": "1.2.1",
  "description": "跨电脑复制粘贴共享",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "agent": "node agent.js",
    "electron": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.clipboard-share.app",
    "productName": "ClipboardShare",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
